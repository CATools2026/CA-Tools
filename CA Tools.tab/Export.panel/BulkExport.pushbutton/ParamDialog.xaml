<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Filename  -  Tools By Chulan"
        Height="620" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="460" MinWidth="640"
        Background="#16091F"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Color x:Key="cBg">#16091F</Color>
        <Color x:Key="cPanel">#221433</Color>
        <Color x:Key="cPanelHi">#2C1B40</Color>
        <Color x:Key="cInput">#311E47</Color>
        <Color x:Key="cStroke">#473058</Color>
        <Color x:Key="cStrokeHi">#6A4E86</Color>
        <Color x:Key="cAccent">#7F77DD</Color>
        <Color x:Key="cAccentHi">#9A91EE</Color>
        <Color x:Key="cAccentDim">#5B53B0</Color>
        <Color x:Key="cTextMain">#ECE6F7</Color>
        <Color x:Key="cTextDim">#B3A4CE</Color>
        <Color x:Key="cRowAlt">#1E1230</Color>
        <Color x:Key="cRowSel">#46326A</Color>
        <Color x:Key="cOrange">#D85A30</Color>

        <SolidColorBrush x:Key="Bg" Color="{DynamicResource cBg}"/>
        <SolidColorBrush x:Key="Panel" Color="{DynamicResource cPanel}"/>
        <SolidColorBrush x:Key="PanelHi" Color="{DynamicResource cPanelHi}"/>
        <SolidColorBrush x:Key="Input" Color="{DynamicResource cInput}"/>
        <SolidColorBrush x:Key="Stroke" Color="{DynamicResource cStroke}"/>
        <SolidColorBrush x:Key="StrokeHi" Color="{DynamicResource cStrokeHi}"/>
        <SolidColorBrush x:Key="Accent" Color="{DynamicResource cAccent}"/>
        <SolidColorBrush x:Key="AccentHi" Color="{DynamicResource cAccentHi}"/>
        <SolidColorBrush x:Key="AccentDim" Color="{DynamicResource cAccentDim}"/>
        <SolidColorBrush x:Key="TextMain" Color="{DynamicResource cTextMain}"/>
        <SolidColorBrush x:Key="TextDim" Color="{DynamicResource cTextDim}"/>
        <SolidColorBrush x:Key="RowAlt" Color="{DynamicResource cRowAlt}"/>
        <SolidColorBrush x:Key="RowSel" Color="{DynamicResource cRowSel}"/>
        <SolidColorBrush x:Key="Orange" Color="{DynamicResource cOrange}"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- BUTTON -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PanelHi}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource StrokeHi}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHi}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnSmall" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="MinWidth" Value="30"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BtnBase}"/>

        <!-- TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CHECKBOX -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="15" Height="15"
                                    Background="{DynamicResource Input}"
                                    BorderBrush="{DynamicResource StrokeHi}"
                                    BorderThickness="1" CornerRadius="3"
                                    VerticalAlignment="Center">
                                <Path x:Name="tick"
                                      Data="M 2,5 L 6,9 L 12,1"
                                      Stroke="White" StrokeThickness="2"
                                      Visibility="Collapsed"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource AccentHi}"/>
                                <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- LISTBOX -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PanelHi}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource RowSel}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GROUPBOX -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{TemplateBinding Header}"
                                       Foreground="{DynamicResource AccentHi}"
                                       FontWeight="SemiBold" FontSize="11"
                                       Margin="2,0,0,4"/>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource Panel}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT : available parameters -->
            <GroupBox Grid.Column="0" Header="Sheet Parameters">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,6">
                        <CheckBox x:Name="chk_include_proj"
                                  Content="Include Project Information Parameters"
                                  Margin="0,0,0,4"
                                  Checked="on_include_proj" Unchecked="on_include_proj"/>
                        <CheckBox x:Name="chk_include_shared"
                                  Content="Include Shared Parameters"
                                  Checked="on_include_shared" Unchecked="on_include_shared"/>
                    </StackPanel>

                    <ListBox x:Name="lst_available" Grid.Row="1"
                             SelectionMode="Extended" MinHeight="180"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Custom Field" VerticalAlignment="Center"
                                   Width="108" Foreground="{DynamicResource TextDim}"/>
                        <TextBox x:Name="txt_custom_field" Width="150" VerticalAlignment="Center"/>
                        <Button x:Name="btn_add_field" Style="{StaticResource BtnSmall}"
                                Content="+" Margin="6,0,0,0" Click="on_add_custom_field"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Custom Separator" VerticalAlignment="Center"
                                   Width="108" Foreground="{DynamicResource TextDim}"/>
                        <TextBox x:Name="txt_custom_sep" Width="150" VerticalAlignment="Center"/>
                        <Button x:Name="btn_add_sep" Style="{StaticResource BtnSmall}"
                                Content="+" Margin="6,0,0,0" Click="on_add_custom_sep"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- MIDDLE : add / remove arrows -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="btn_add" Style="{StaticResource BtnBase}"
                        Content="+" Width="44" Height="40" Margin="0,0,0,10"
                        Padding="0" FontSize="22" FontWeight="Bold"
                        ToolTip="Add selected" Click="on_add"/>
                <Button x:Name="btn_remove" Style="{StaticResource BtnBase}"
                        Content="&#x2212;" Width="44" Height="40"
                        Padding="0" FontSize="22" FontWeight="Bold"
                        ToolTip="Remove selected" Click="on_remove"/>
            </StackPanel>

            <!-- RIGHT : selected parameters -->
            <GroupBox Grid.Column="2" Header="Selected Parameters">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox x:Name="chk_field_sep" Content="Field Separator"
                                  VerticalAlignment="Center"
                                  Checked="on_field_sep_toggle" Unchecked="on_field_sep_toggle"/>
                        <TextBox x:Name="txt_field_sep" Text="-" Width="40"
                                 Margin="8,0,0,0" VerticalAlignment="Center"
                                 TextChanged="on_field_sep_text"/>
                    </StackPanel>

                    <ListBox x:Name="lst_selected" Grid.Row="1" Grid.Column="0"
                             SelectionMode="Extended" MinHeight="220" Margin="0,0,8,0"/>

                    <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top">
                        <Button x:Name="btn_up" Style="{StaticResource BtnSmall}"
                                Content="&#x25B2;" Width="34" Margin="0,0,0,5"
                                FontFamily="Segoe UI Symbol" FontSize="15"
                                ToolTip="Move up" Click="on_move_up"/>
                        <Button x:Name="btn_down" Style="{StaticResource BtnSmall}"
                                Content="&#x25BC;" Width="34" Margin="0,0,0,5"
                                FontFamily="Segoe UI Symbol" FontSize="15"
                                ToolTip="Move down" Click="on_move_down"/>
                        <Button x:Name="btn_reset" Style="{StaticResource BtnSmall}"
                                Content="&#x21BB;" Width="34"
                                FontFamily="Segoe UI Symbol" FontSize="16"
                                ToolTip="Reset" Click="on_reset"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- saved naming formats -->
        <GroupBox Grid.Row="1" Header="Saved Naming Formats" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cmb_saved" Width="260" VerticalAlignment="Center"
                          ToolTip="Pick a previously saved naming format"/>
                <Button x:Name="btn_load_format" Style="{StaticResource BtnSmall}"
                        Content="Load" Width="80" Margin="8,0,0,0"
                        ToolTip="Apply the selected saved format"
                        Click="on_load_format"/>
                <Button x:Name="btn_save_format" Style="{StaticResource BtnSmall}"
                        Content="Save Current..." Width="120" Margin="8,0,0,0"
                        ToolTip="Save the current selected parameters as a reusable format"
                        Click="on_save_format"/>
                <Button x:Name="btn_delete_format" Style="{StaticResource BtnSmall}"
                        Content="Delete" Width="80" Margin="8,0,0,0"
                        ToolTip="Delete the selected saved format"
                        Click="on_delete_format"/>
            </StackPanel>
        </GroupBox>

        <!-- preview + footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource PanelHi}"
                    BorderBrush="{DynamicResource Stroke}" BorderThickness="1"
                    CornerRadius="5" Padding="10,6" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Preview: " Foreground="{DynamicResource TextDim}"/>
                    <TextBlock x:Name="lbl_preview" Text="" Foreground="{DynamicResource AccentHi}"
                               FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                <Button x:Name="btn_cancel" Style="{StaticResource BtnBase}"
                        Content="Cancel" Width="90" Margin="0,0,8,0" Click="on_cancel"/>
                <Button x:Name="btn_ok" Style="{StaticResource BtnPrimary}"
                        Content="Ok" Width="90" Click="on_ok"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
