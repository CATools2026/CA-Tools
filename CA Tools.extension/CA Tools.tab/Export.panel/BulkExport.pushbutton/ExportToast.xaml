<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Export"
        Width="380" Height="170"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">

    <Border Background="#221433"
            BorderBrush="#6A4E86"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20,16">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="4" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- close (X) -->
            <Button x:Name="btn_close" Content="&#x2715;"
                    Width="24" Height="24"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-4,-4,0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#B3A4CE" FontSize="12"
                    Cursor="Hand"
                    Click="on_close">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2C1B40"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- icon + message -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,36,0">
                <!-- checkmark circle -->
                <Border Width="36" Height="36" CornerRadius="18"
                        Background="#2C1B40" BorderBrush="#6A4E86" BorderThickness="1"
                        Margin="0,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="&#x2713;" FontSize="18" FontWeight="Bold"
                               Foreground="#7F77DD"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="lbl_title" Text="Export completed."
                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                               Foreground="#ECE6F7"/>
                    <TextBlock x:Name="lbl_sub" Text=""
                               FontFamily="Segoe UI" FontSize="11" Foreground="#B3A4CE"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- open folder button -->
            <Button x:Name="btn_open_folder" Content="Open Folder"
                    Grid.Row="1" HorizontalAlignment="Right"
                    Padding="14,6" Margin="0,14,0,0"
                    FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                    Foreground="White" Cursor="Hand"
                    Click="on_open_folder">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#7F77DD"/>
                        <Setter Property="BorderBrush" Value="#9A91EE"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#9A91EE"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#5B53B0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
