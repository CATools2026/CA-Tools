<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Export"
        Width="340" Height="130"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">

    <Border Background="#1A0F2E"
            BorderBrush="#6A4E86"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24,20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Status label e.g. "[1/2] Reading Sheets from document..." -->
            <TextBlock x:Name="lbl_status"
                       Grid.Row="0"
                       Text="[1/2] Reading Sheets from document..."
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="#ECE6F7"
                       HorizontalAlignment="Left"/>

            <!-- Progress bar row -->
            <Border Grid.Row="2"
                    Background="#2C1B40"
                    BorderBrush="#6A4E86"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Animated dots label -->
                    <TextBlock x:Name="lbl_dots"
                               Grid.Column="0"
                               Text="Completed 0%"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#B3A4CE"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
