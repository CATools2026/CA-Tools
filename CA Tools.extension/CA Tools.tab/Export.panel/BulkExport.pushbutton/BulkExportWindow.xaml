<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Export"
        Height="640" Width="940"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="560" MinWidth="820"
        Background="#16091F"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- ===================== PALETTE ===================== -->
        <Color x:Key="cBg">#16091F</Color>
        <Color x:Key="cPanel">#221433</Color>
        <Color x:Key="cPanelHi">#2C1B40</Color>
        <Color x:Key="cInput">#311E47</Color>
        <Color x:Key="cStroke">#473058</Color>
        <Color x:Key="cStrokeHi">#6A4E86</Color>
        <Color x:Key="cAccent">#7F77DD</Color>
        <Color x:Key="cAccentHi">#9A91EE</Color>
        <Color x:Key="cAccentDim">#5B53B0</Color>
        <Color x:Key="cTextMain">#ECE6F7</Color>
        <Color x:Key="cTextDim">#B3A4CE</Color>
        <Color x:Key="cRowAlt">#1E1230</Color>
        <Color x:Key="cRowSel">#46326A</Color>
        <Color x:Key="cOrange">#D85A30</Color>

        <SolidColorBrush x:Key="Bg" Color="{DynamicResource cBg}"/>
        <SolidColorBrush x:Key="Panel" Color="{DynamicResource cPanel}"/>
        <SolidColorBrush x:Key="PanelHi" Color="{DynamicResource cPanelHi}"/>
        <SolidColorBrush x:Key="Input" Color="{DynamicResource cInput}"/>
        <SolidColorBrush x:Key="Stroke" Color="{DynamicResource cStroke}"/>
        <SolidColorBrush x:Key="StrokeHi" Color="{DynamicResource cStrokeHi}"/>
        <SolidColorBrush x:Key="Accent" Color="{DynamicResource cAccent}"/>
        <SolidColorBrush x:Key="AccentHi" Color="{DynamicResource cAccentHi}"/>
        <SolidColorBrush x:Key="AccentDim" Color="{DynamicResource cAccentDim}"/>
        <SolidColorBrush x:Key="TextMain" Color="{DynamicResource cTextMain}"/>
        <SolidColorBrush x:Key="TextDim" Color="{DynamicResource cTextDim}"/>
        <SolidColorBrush x:Key="RowAlt" Color="{DynamicResource cRowAlt}"/>
        <SolidColorBrush x:Key="RowSel" Color="{DynamicResource cRowSel}"/>
        <SolidColorBrush x:Key="Orange" Color="{DynamicResource cOrange}"/>

        <!-- ===================== BASE TEXT ===================== -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ===================== BUTTON ===================== -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PanelHi}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource StrokeHi}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHi}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHi}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSmall" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BtnBase}"/>

        <!-- ===================== TEXTBOX ===================== -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== CHECKBOX ===================== -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="15" Height="15"
                                    Background="{DynamicResource Input}"
                                    BorderBrush="{DynamicResource StrokeHi}"
                                    BorderThickness="1" CornerRadius="3"
                                    VerticalAlignment="Center">
                                <Path x:Name="tick"
                                      Data="M 2,5 L 6,9 L 12,1"
                                      Stroke="White" StrokeThickness="2"
                                      Visibility="Collapsed"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource AccentHi}"/>
                                <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== RADIOBUTTON ===================== -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Grid Width="16" Height="16" VerticalAlignment="Center">
                                <Ellipse x:Name="outer"
                                         Fill="{DynamicResource Input}"
                                         Stroke="{DynamicResource StrokeHi}"
                                         StrokeThickness="1"/>
                                <Ellipse x:Name="dot" Width="7" Height="7"
                                         Fill="White" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outer" Property="Fill" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource AccentHi}"/>
                                <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== COMBOBOX ===================== -->
        <Style x:Key="ComboToggle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{DynamicResource Input}"
                                BorderBrush="{DynamicResource Stroke}"
                                BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M 0,0 L 8,0 L 4,5 Z" Fill="{DynamicResource TextDim}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource StrokeHi}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="tgl"
                                          Style="{StaticResource ComboToggle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="cp"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,24,0"
                                              IsHitTestVisible="False"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource PanelHi}"
                                        BorderBrush="{DynamicResource StrokeHi}"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="300">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== LISTBOX ===================== -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PanelHi}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource RowSel}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== GROUPBOX ===================== -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{TemplateBinding Header}"
                                       Foreground="{DynamicResource AccentHi}"
                                       FontWeight="SemiBold" FontSize="11"
                                       Margin="2,0,0,4"/>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource Panel}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== TABITEM (left icon sidebar) ===================== -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Width="60" Height="64" Margin="4,6"
                                Background="Transparent" CornerRadius="14">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PanelHi}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabPanel">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- ===================== PROGRESSBAR ===================== -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <Grid x:Name="PART_Track" ClipToBounds="True">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="9"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== DATAGRID ===================== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="RowBackground" Value="{DynamicResource Panel}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource RowAlt}"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="26"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="ColumnHeaderHeight" Value="30"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PanelHi}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentHi}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowSel}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelHi}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- ===================== LAYOUT ===================== -->
    <Grid Margin="14,14,14,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ HEADER : LOGO ============ -->
        <Grid Grid.Row="0" Margin="0,0,0,12" Height="58" ClipToBounds="True">
            <!-- decorative accent stroke -->
            <Path Stroke="{DynamicResource AccentDim}" StrokeThickness="2.5"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Opacity="0.30" Stretch="Fill" HorizontalAlignment="Stretch"
                  Height="46" VerticalAlignment="Top" Margin="0,-4,0,0"
                  Data="M 4,30 C 90,2 170,52 260,16 C 340,-6 430,44 520,14 C 600,-8 700,38 800,10 C 880,-10 960,40 1040,12"/>

            <!-- logo mark -->
            <Border Width="62" Height="50" Background="#0B0410"
                    CornerRadius="10" HorizontalAlignment="Left" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="CA" Foreground="White" FontWeight="Bold"
                               FontSize="19" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock Text="TOOLS" Foreground="{DynamicResource AccentHi}"
                               FontSize="8" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Margin="0,-3,0,2"/>
                </StackPanel>
            </Border>

            <!-- profile bar -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Stroke}" BorderThickness="1"
                    CornerRadius="8" Padding="8,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Profile" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextDim}" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmb_profile" Width="180" VerticalAlignment="Center"
                              SelectionChanged="on_profile_changed"
                              ToolTip="Select a saved export profile — its settings load automatically"/>
                    <Button x:Name="btn_profile_add" Style="{StaticResource BtnSmall}"
                            Content="+" Width="30" Margin="6,0,0,0"
                            ToolTip="Create a new profile" Click="on_profile_add"/>
                    <Button x:Name="btn_profile_save" Style="{StaticResource BtnSmall}"
                            Content="Save" Width="52" Margin="6,0,0,0"
                            ToolTip="Save the current settings into the selected profile"
                            Click="on_profile_save"/>
                    <Button x:Name="btn_profile_export" Style="{StaticResource BtnSmall}"
                            Content="Export" Width="60" Margin="6,0,0,0"
                            ToolTip="Save the selected profile to an XML file you can reuse later"
                            Click="on_profile_export"/>
                    <Button x:Name="btn_profile_delete" Style="{StaticResource BtnSmall}"
                            Content="Delete" Width="60" Margin="6,0,0,0"
                            ToolTip="Delete the selected profile" Click="on_profile_delete"/>
                </StackPanel>
            </Border>
        </Grid>

        <TabControl x:Name="tabs" Grid.Row="1" TabStripPlacement="Left" SelectionChanged="on_tab_changed">

            <!-- ============ TAB 1 : SELECT ============ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="48">
                        <Path Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                              Data="M4,2 L4,17 L8,13 L11,18 L13,17 L10,12 L16,12 Z"/>
                        <TextBlock Text="Select" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{DynamicResource Panel}"
                        BorderBrush="{DynamicResource Stroke}"
                        BorderThickness="1" CornerRadius="10" Padding="14" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- top toolbar : mode + filter + search -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="240"/>
                            </Grid.ColumnDefinitions>

                            <RadioButton x:Name="rb_sheets" Grid.Column="0"
                                         Content="Sheets" GroupName="mode"
                                         IsChecked="True" VerticalAlignment="Center"
                                         Margin="0,0,14,0" Checked="on_mode_changed"/>
                            <RadioButton x:Name="rb_views" Grid.Column="1"
                                         Content="Views" GroupName="mode"
                                         VerticalAlignment="Center" Margin="0,0,16,0"
                                         Checked="on_mode_changed"/>

                            <ComboBox x:Name="cmb_view_filter" Grid.Column="2"
                                      Width="150" Margin="0,0,16,0"
                                      VerticalAlignment="Center"
                                      SelectionChanged="on_view_filter_changed"/>

                            <Grid Grid.Column="4">
                                <TextBox x:Name="txt_search"
                                         VerticalAlignment="Center"
                                         TextChanged="on_search_changed"/>
                                <TextBlock Text="Search..." Foreground="{DynamicResource TextDim}"
                                           Margin="8,0,0,0" IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           x:Name="ph_search"/>
                            </Grid>
                        </Grid>

                        <!-- second toolbar : sheet-set + naming actions -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Sheet set:" VerticalAlignment="Center"
                                       Margin="0,0,8,0" Foreground="{DynamicResource TextDim}"/>

                            <ComboBox x:Name="cmb_vs_set" Grid.Column="1"
                                      Margin="0,0,10,0" VerticalAlignment="Center"
                                      SelectionChanged="on_vs_set_changed"/>

                            <Button x:Name="btn_create_set" Grid.Column="2"
                                    Style="{StaticResource BtnSmall}"
                                    Content="Create Set" Margin="0,0,8,0"
                                    Click="on_create_set"/>
                            <Button x:Name="btn_delete_set" Grid.Column="3"
                                    Style="{StaticResource BtnSmall}"
                                    Content="Delete Set" Margin="0,0,8,0"
                                    Click="on_delete_set"/>

                            <CheckBox x:Name="chk_only_set" Grid.Column="4"
                                      Content="Show only sheets in set"
                                      VerticalAlignment="Center" Margin="4,0,8,0"
                                      ToolTip="When ticked, the list below shows only the sheets/views assigned to the selected sheet set. Untick to show everything again."
                                      Checked="on_only_set_changed" Unchecked="on_only_set_changed"/>

                            <Button x:Name="btn_edit_filename" Grid.Column="6"
                                    Style="{StaticResource BtnBase}"
                                    Content="Edit the Filename"
                                    Click="on_edit_filename"/>
                        </Grid>

                        <!-- ============ SHEET ORDERING ============ -->
                        <GroupBox Grid.Row="2" Header="Sheet Ordering" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- row 0 : toggles -->
                                <WrapPanel Grid.Row="0" Orientation="Horizontal">
                                    <CheckBox x:Name="chk_reverse"
                                              Content="Reverse Print Order"
                                              Margin="0,0,20,6"
                                              Checked="on_ordering_changed" Unchecked="on_ordering_changed"/>
                                </WrapPanel>

                                <!-- row 1 : index controls -->
                                <Grid Grid.Row="1" Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Index Digits"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{DynamicResource TextDim}"/>
                                    <ComboBox x:Name="cmb_index_digits" Grid.Column="1"
                                              Width="70" Height="24" VerticalAlignment="Center"
                                              SelectionChanged="on_ordering_changed"/>

                                    <TextBlock Grid.Column="3" Text="Index Start"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{DynamicResource TextDim}"/>
                                    <TextBox x:Name="txt_index_start" Grid.Column="4"
                                             Text="0" Width="90" VerticalAlignment="Center"
                                             TextChanged="on_ordering_changed"/>
                                    <Button x:Name="btn_index_reset" Grid.Column="5"
                                            Style="{StaticResource BtnSmall}"
                                            Content="Reset" Margin="8,0,0,0"
                                            Click="on_index_reset"/>

                                    <Button x:Name="btn_print_order" Grid.Column="7"
                                            Style="{StaticResource BtnBase}"
                                            Content="Print Order..."
                                            Click="on_print_order"/>
                                </Grid>

                                <!-- row 2 : drawing list -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Drawing List"
                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                               Foreground="{DynamicResource TextDim}"/>
                                    <Button x:Name="btn_load_list" Grid.Column="1"
                                            Style="{StaticResource BtnSmall}"
                                            Content="Load Excel / CSV..." Margin="0,0,8,0"
                                            Click="on_load_list"/>
                                    <Button x:Name="btn_export_drawing_list" Grid.Column="2"
                                            Style="{StaticResource BtnSmall}"
                                            Content="Export CSV..." Margin="0,0,8,0"
                                            Click="on_export_drawing_list"/>
                                    <Button x:Name="btn_clear_list" Grid.Column="3"
                                            Style="{StaticResource BtnSmall}"
                                            Content="Clear"
                                            Click="on_clear_list"/>
                                    <TextBlock x:Name="lbl_list_status" Grid.Column="4"
                                               Text="(no list loaded — using schedule order)"
                                               VerticalAlignment="Center" Margin="14,0,0,0"
                                               FontStyle="Italic"
                                               Foreground="{DynamicResource TextDim}"/>
                                </Grid>
                            </Grid>
                        </GroupBox>

                        <!-- data grid -->
                        <DataGrid x:Name="dg_selection" Grid.Row="3">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPrintable}" Value="False">
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="40" CanUserSort="False">
                                    <DataGridTemplateColumn.Header>
                                        <CheckBox x:Name="chk_all" HorizontalAlignment="Center"
                                                  Checked="on_check_all" Unchecked="on_check_all"
                                                  Margin="0"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"
                                                      Checked="on_row_check" Unchecked="on_row_check"
                                                      Margin="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Index" Width="60"
                                                    Binding="{Binding Index}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Sheet Number" Width="150"
                                                    Binding="{Binding SheetNumber}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Sheet Name" Width="*"
                                                    Binding="{Binding SheetName}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Revision" Width="90"
                                                    Binding="{Binding Revision}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Size" Width="90"
                                                    Binding="{Binding Size}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Custom Filename" Width="260"
                                                    Binding="{Binding CustomFilename}" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ============ TAB 2 : PDF/CAD ============ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="48">
                        <Path Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                              StrokeThickness="1.6" StrokeLineJoin="Round" Fill="Transparent"
                              Data="M5,2 H12 L16,6 V18 H5 Z M12,2 V6 H16"/>
                        <TextBlock Text="PDF/CAD" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{DynamicResource Panel}"
                        BorderBrush="{DynamicResource Stroke}"
                        BorderThickness="1" CornerRadius="10" Padding="14" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- format cards -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="{DynamicResource Input}"
                                    BorderBrush="{DynamicResource Stroke}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,8" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="26" Height="32" Background="{DynamicResource Orange}"
                                            CornerRadius="3" Margin="0,0,10,0">
                                        <TextBlock Text="PDF" Foreground="White" FontSize="9"
                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <CheckBox x:Name="chk_pdf" Content="PDF" IsChecked="True"
                                              VerticalAlignment="Center"
                                              Checked="on_format_toggle" Unchecked="on_format_toggle"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource Input}"
                                    BorderBrush="{DynamicResource Stroke}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="26" Height="32" Background="{DynamicResource AccentDim}"
                                            CornerRadius="3" Margin="0,0,10,0">
                                        <TextBlock Text="DWG" Foreground="White" FontSize="9"
                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <CheckBox x:Name="chk_dwg" Content="DWG"
                                              VerticalAlignment="Center"
                                              Checked="on_format_toggle" Unchecked="on_format_toggle"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- DWG export setup (named layer/color mapping from the
                             Modify DWG/DXF Export Setup dialog in Revit) -->
                        <Border x:Name="pnl_dwg_setup" Grid.Row="1" Background="{DynamicResource Input}"
                                BorderBrush="{DynamicResource Stroke}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,8" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="DWG Export Setup:" VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <ComboBox x:Name="cmb_dwg_setup" Width="260" Height="26"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Loaded from this model's saved export setups, so colors and layers match what's configured in Revit."
                                           Foreground="{DynamicResource TextDim}" FontSize="11"
                                           TextWrapping="Wrap" Width="320"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 3-column options -->
                        <Grid x:Name="pnl_pdf_options" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- column 1 -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <GroupBox Header="Paper Size">
                                    <TextBlock Text="Set the paper size in the next tab 'Generate'."
                                               TextWrapping="Wrap" Foreground="{DynamicResource TextDim}"/>
                                </GroupBox>
                                <GroupBox Header="Paper Placement">
                                    <StackPanel>
                                        <RadioButton x:Name="rb_center" Content="Center"
                                                     GroupName="placement" IsChecked="True"/>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton x:Name="rb_offset" Content="Offset from corner"
                                                         GroupName="placement" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="cmb_margin" Width="100" Height="24"
                                                      Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="X =" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox x:Name="txt_offx" Text="0.00in" Width="60" Margin="0,0,12,0"/>
                                            <TextBlock Text="Y =" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox x:Name="txt_offy" Text="0.00in" Width="60"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox Header="Zoom">
                                    <StackPanel>
                                        <RadioButton x:Name="rb_fit" Content="Fit to Page" GroupName="zoom"/>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton x:Name="rb_zoom" Content="Zoom" GroupName="zoom"
                                                         IsChecked="True" VerticalAlignment="Center"/>
                                            <TextBox x:Name="txt_zoom" Text="100" Width="48"
                                                     Margin="8,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="% Size" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>

                            <!-- column 2 -->
                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                <GroupBox Header="Orientation">
                                    <TextBlock Text="Set the paper orientation in the next tab 'Generate'."
                                               TextWrapping="Wrap" Foreground="{DynamicResource TextDim}"/>
                                </GroupBox>
                                <GroupBox Header="Hide Line Views">
                                    <StackPanel>
                                        <TextBlock Text="Using" Foreground="{DynamicResource TextDim}" Margin="0,0,0,4"/>
                                        <RadioButton x:Name="rb_vector" Content="Vector Processing"
                                                     GroupName="hideline" IsChecked="True"/>
                                        <RadioButton x:Name="rb_raster" Content="Raster Processing"
                                                     GroupName="hideline"/>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox Header="Appearance">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Raster Quality"
                                                   VerticalAlignment="Center" Margin="0,0,8,4"/>
                                        <ComboBox x:Name="cmb_raster" Grid.Row="0" Grid.Column="1"
                                                  Height="24" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Colors"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="cmb_colors" Grid.Row="1" Grid.Column="1" Height="24"/>
                                    </Grid>
                                </GroupBox>
                            </StackPanel>

                            <!-- column 3 -->
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <GroupBox Header="Options">
                                    <StackPanel>
                                        <CheckBox x:Name="chk_viewlinks" Content="View links in blue (Color prints only)" IsChecked="True"/>
                                        <CheckBox x:Name="chk_hideref" Content="Hide ref/work planes" IsChecked="True"/>
                                        <CheckBox x:Name="chk_hidetags" Content="Hide unreferenced view tags" IsChecked="True"/>
                                        <CheckBox x:Name="chk_hidescope" Content="Hide scope boxes" IsChecked="True"/>
                                        <CheckBox x:Name="chk_hidecrop" Content="Hide crop boundaries" IsChecked="True"/>
                                        <CheckBox x:Name="chk_halftone" Content="Replace halftone with thin lines"/>
                                        <CheckBox x:Name="chk_maskcoin" Content="Region edges mask coincident lines"/>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox Header="File">
                                    <StackPanel>
                                        <RadioButton x:Name="rb_separate" Content="Create separate files"
                                                     GroupName="filemode" IsChecked="True"/>
                                        <RadioButton x:Name="rb_combine" Content="Combine multiple views/sheets into a single file"
                                                     GroupName="filemode"/>
                                        <CheckBox x:Name="chk_keepjump" Content="Keep jump to section" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="File Name" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox x:Name="txt_filename" Width="200"/>
                                        </StackPanel>
                                        <Button x:Name="btn_order" Style="{StaticResource BtnSmall}"
                                                Content="Print Order..." Margin="0,8,0,0"
                                                HorizontalAlignment="Left" Click="on_print_order"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ============ TAB 3 : GENERATE ============ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="48">
                        <Path Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                              Data="M11,2 L4,11 H9 L8,18 L16,8 H11 Z"/>
                        <TextBlock Text="Generate" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{DynamicResource Panel}"
                        BorderBrush="{DynamicResource Stroke}"
                        BorderThickness="1" CornerRadius="10" Padding="14" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- export rules -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="Export Rules">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Folder Selection:" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBox x:Name="txt_folder" Width="320" VerticalAlignment="Center"/>
                                        <Button x:Name="btn_browse" Style="{StaticResource BtnSmall}"
                                                Content="..." Margin="6,0,0,0" Click="on_browse"/>
                                    </StackPanel>

                                    <RadioButton x:Name="rb_save_same" Content="Save all files in the same folder location"
                                                 GroupName="savemode" IsChecked="True"/>
                                    <RadioButton x:Name="rb_save_split" Content="Save and split files by file format"
                                                 GroupName="savemode"/>
                                </StackPanel>
                            </GroupBox>

                            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                <TextBlock x:Name="lbl_progress" Text="Completed 0%"
                                           Margin="0,4,0,6" Foreground="{DynamicResource TextMain}"/>
                                <ComboBox x:Name="cmb_report" Height="26" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- progress + paper size -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cmb_paper_orient" Grid.Column="0" Width="220"
                                      Height="26" HorizontalAlignment="Left"
                                      SelectionChanged="on_paper_orient_changed"/>
                            <ProgressBar x:Name="pbar" Grid.Column="1" Value="0" Maximum="100"
                                         Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- create grid -->
                        <DataGrid x:Name="dg_create" Grid.Row="2">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="40" CanUserSort="False">
                                    <DataGridTemplateColumn.Header>
                                        <CheckBox x:Name="chk_all_create" HorizontalAlignment="Center"
                                                  IsChecked="True"
                                                  Checked="on_check_all_create" Unchecked="on_check_all_create"
                                                  Margin="0"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" Margin="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="View/Sheet Number" Width="160"
                                                    Binding="{Binding Number}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="View/Sheet Name" Width="*"
                                                    Binding="{Binding Name}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Format" Width="80"
                                                    Binding="{Binding Format}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Size" Width="90"
                                                    Binding="{Binding Size}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Orientation" Width="110"
                                                    Binding="{Binding Orientation}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Progress" Width="160"
                                                    Binding="{Binding Progress}" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ============ FOOTER ============ -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource PanelHi}"
                    BorderBrush="{DynamicResource Stroke}" BorderThickness="1"
                    CornerRadius="5" Padding="12,6" VerticalAlignment="Center">
                <TextBlock x:Name="lbl_status" Text="0 sheets and 0 views selected. Total: 0"
                           Foreground="{DynamicResource TextMain}"/>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                <Button x:Name="btn_back" Style="{StaticResource BtnBase}"
                        Content="Back" Width="90" Margin="0,0,8,0"
                        IsEnabled="False" Click="on_back"/>
                <Button x:Name="btn_next" Style="{StaticResource BtnPrimary}"
                        Content="Next" Width="90" Margin="0,0,8,0" Click="on_next"/>
                <Button x:Name="btn_create" Style="{StaticResource BtnPrimary}"
                        Content="Generate" Width="110" Visibility="Collapsed" Click="on_create"/>
            </StackPanel>
        </Grid>

        <!-- ============ COPYRIGHT FOOTER ============ -->
        <TextBlock Grid.Row="3"
                   Text="Copyright © 2026 Chulan Adasuriya"
                   Foreground="{DynamicResource TextDim}"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,8"/>
    </Grid>
</Window>
