<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Parallel Runs"
        Height="640" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#221A30"
        FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <!-- Light input fields on the dark-purple chrome (readable, on-brand) -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F5F5F3"/>
            <Setter Property="Foreground" Value="#221A30"/>
            <Setter Property="BorderBrush" Value="#7F77DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F5F5F3"/>
            <Setter Property="Foreground" Value="#221A30"/>
            <Setter Property="BorderBrush" Value="#7F77DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#221A30"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5F5F3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F5F5F3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Flat purple button with orange hover -->
        <Style x:Key="CAButton" TargetType="Button">
            <Setter Property="Background" Value="#7F77DD"/>
            <Setter Property="Foreground" Value="#F5F5F3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D85A30"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B8481F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (orange) button for Create -->
        <Style x:Key="CAButtonPrimary" TargetType="Button" BasedOn="{StaticResource CAButton}">
            <Setter Property="Background" Value="#D85A30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E8703F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B8481F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PART_Intro"
                   Text="Set how many parallel runs to create, then adjust each run's size, service and spacing."
                   TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#C9C4EE"/>

        <!-- Layout / count / side -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Layout:" Width="55"/>
            <ComboBox x:Name="PART_Layout" Width="150">
                <ComboBoxItem Content="Parallel (side by side)" IsSelected="True"/>
                <ComboBoxItem Content="Stack (vertical)"/>
            </ComboBox>
            <TextBlock x:Name="PART_CountLbl" Text="Number of runs:" Width="105" Margin="18,0,0,0"/>
            <TextBox x:Name="PART_Count" Width="50" Text="5"/>
            <CheckBox x:Name="PART_Flip" Content="Flip side" Margin="18,0,0,0"/>
            <TextBlock x:Name="PART_DirLbl" Text="Direction:" Margin="18,0,0,0"
                       Visibility="Collapsed"/>
            <ComboBox x:Name="PART_Direction" Width="80" Margin="6,0,0,0" Visibility="Collapsed">
                <ComboBoxItem Content="Up" IsSelected="True"/>
                <ComboBoxItem Content="Down"/>
            </ComboBox>
        </StackPanel>

        <!-- Spacing mode -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Spacing mode:" Width="95"/>
            <ComboBox x:Name="PART_Mode" Width="200">
                <ComboBoxItem Content="Center to center" IsSelected="True"/>
                <ComboBoxItem Content="Clear gap (edge to edge)"/>
            </ComboBox>
        </StackPanel>

        <!-- Defaults -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="LblDefSpacing" Text="Default spacing (mm):" Width="130"/>
            <TextBox x:Name="PART_DefSpacing" Width="60" Text="300"/>
            <TextBlock x:Name="LblDefW" Text="Width (mm):" Width="75" Margin="15,0,0,0"/>
            <TextBox x:Name="PART_DefWidth" Width="60"/>
            <TextBlock x:Name="LblDefH" Text="Height (mm):" Width="78" Margin="12,0,0,0"/>
            <TextBox x:Name="PART_DefHeight" Width="60"/>
            <Button x:Name="PART_Generate" Content="Generate rows" Width="115"
                    Height="26" Margin="15,0,0,0" Style="{StaticResource CAButton}"/>
        </StackPanel>

        <!-- Column headers -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,2,0,4">
            <TextBlock x:Name="HdrRun" Text="Run" Width="84" FontWeight="Bold" Foreground="#C9C4EE"/>
            <TextBlock x:Name="HdrSize1" Text="Width (mm)" Width="92" FontWeight="Bold" Foreground="#C9C4EE"/>
            <TextBlock x:Name="HdrSize2" Text="Height (mm)" Width="92" FontWeight="Bold" Foreground="#C9C4EE"/>
            <TextBlock x:Name="HdrService" Text="Service Type" Width="204" FontWeight="Bold" Foreground="#C9C4EE"/>
            <TextBlock x:Name="HdrSpacing" Text="Spacing (mm)" Width="92" FontWeight="Bold" Foreground="#C9C4EE"/>
        </StackPanel>

        <Border Grid.Row="5" BorderThickness="1" BorderBrush="#7F77DD" CornerRadius="3"
                Background="#2C2340">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PART_Rows" Margin="6"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="6" Background="#2C2340" CornerRadius="3" Margin="0,10,0,0" Padding="0,5">
            <TextBlock Text="Copyright © 2026 Chulan Adasuriya"
                       HorizontalAlignment="Center" Foreground="#FFFFFF" FontSize="11"/>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="PART_Create" Content="Create" Width="95" Height="30" Margin="0,0,8,0"
                    IsDefault="True" Style="{StaticResource CAButtonPrimary}"/>
            <Button x:Name="PART_Cancel" Content="Cancel" Width="95" Height="30"
                    IsCancel="True" Style="{StaticResource CAButton}"/>
        </StackPanel>
    </Grid>
</Window>
